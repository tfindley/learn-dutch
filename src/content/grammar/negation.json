{
  "kind": "grammar",
  "id": "negation",
  "order": 3,
  "tag": "GRAMMAR · NEGATION",
  "title": {
    "nl": "niet vs. geen",
    "en": "Two Ways to Say No"
  },
  "difficulty": "medium",
  "shortcut": "'geen' replaces 'een' or no article. 'niet' negates everything else.",
  "explanation": "Dutch has two negation words. The rule is simple once you see the pattern.",
  "patterns": [
    {
      "rule": "geen = negates nouns (replaces 'een' or no article)",
      "examples": [
        {
          "caption": "'I have no car' — geen replaces 'een'",
          "labels":  ["SUBJECT", "VERB", "GEEN", "NOUN"],
          "words":   ["Ik",      "heb",  "geen", "auto"],
          "english": ["I",       "have", "no",   "car"]
        },
        {
          "caption": "'I have no time' — geen replaces zero article",
          "labels":  ["SUBJECT", "VERB", "GEEN", "NOUN"],
          "words":   ["Ik",      "heb",  "geen", "tijd"],
          "english": ["I",       "have", "no",   "time"]
        }
      ]
    },
    {
      "rule": "niet = negates verbs, adjectives, adverbs",
      "examples": [
        {
          "caption": "'I don't work' — niet negates the verb",
          "labels":  ["SUBJECT", "VERB", "NIET"],
          "words":   ["Ik",      "werk", "niet"],
          "english": ["I",       "work", "not"]
        },
        {
          "caption": "'It is not good' — niet negates the adjective",
          "labels":  ["SUBJECT", "VERB", "NIET", "ADJECTIVE"],
          "words":   ["Het",     "is",   "niet", "goed"],
          "english": ["It",      "is",   "not",  "good"]
        }
      ]
    },
    {
      "rule": "niet = negates SPECIFIC nouns (those with de/het)",
      "examples": [
        {
          "caption": "'I don't have THE car' — niet because the noun is specific (has 'de')",
          "labels":  ["SUBJECT", "VERB", "ARTICLE", "NOUN", "NIET"],
          "words":   ["Ik",      "heb",  "de",      "auto", "niet"],
          "english": ["I",       "have", "the",     "car",  "not"]
        }
      ]
    },
    {
      "rule": "niet comes BEFORE separable prefix at the end",
      "examples": [
        {
          "caption": "'I'm not coming along' — niet sits just before the prefix 'mee'",
          "labels":  ["SUBJECT", "VERB", "NIET", "PREFIX"],
          "words":   ["Ik",      "ga",   "niet", "mee"],
          "english": ["I",       "go",   "not",  "along"]
        }
      ]
    }
  ],
  "memory": "🧠 geen = 'no [thing]' (/dev/null for nouns). niet = toggle switch for everything else.",
  "examples": [
    {
      "caption": "geen — 'I don't drink coffee' (general — no article)",
      "labels":  ["SUBJECT", "VERB",  "GEEN", "NOUN"],
      "words":   ["Ik",      "drink", "geen", "koffie"],
      "english": ["I",       "drink", "no",   "coffee"]
    },
    {
      "caption": "niet — 'I'm not drinking THE coffee' (specific cup, has 'de')",
      "labels":  ["SUBJECT", "VERB",  "ARTICLE", "NOUN",   "NIET"],
      "words":   ["Ik",      "drink", "de",      "koffie", "niet"],
      "english": ["I",       "drink", "the",     "coffee", "not"],
      "note": "Adding 'de' switches the negation from geen → niet. The noun is now specific (this particular coffee), not general."
    }
  ],
  "practice": [
    {
      "role": "A",
      "nl": "Heb jij een auto?",
      "en": "Do you have a car?"
    },
    {
      "role": "B",
      "nl": "Nee, ik heb geen auto.",
      "en": "No, I have no car."
    },
    {
      "role": "A",
      "nl": "Werk jij vandaag?",
      "en": "Are you working today?"
    },
    {
      "role": "B",
      "nl": "Nee, ik werk vandaag niet.",
      "en": "No, I'm not working today."
    }
  ]
}
