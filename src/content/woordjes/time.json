    },
    {
      "nl": "vandaag",
      "phonetic": "fan-DAHKH",
      "en": "today",
      "tip": "Van + dag (of + day). Soft 'g' at end."
    },
    {
      "nl": "morgen",
      "phonetic": "MOR-khun",
      "en": "tomorrow / morning",
      "tip": "Context tells you which. 'Morgenochtend' = tomorrow morning."
    },
    {
      "nl": "gisteren",
      "phonetic": "KHIS-tuh-run",
      "en": "yesterday",
      "tip": "Soft 'g' at start."
    },
    {
