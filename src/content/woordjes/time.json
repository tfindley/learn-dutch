    },
    {
      "nl": "het seizoen",
      "phonetic": "huht say-ZOON",
      "en": "the season",
      "tip": "French origin. Plural: de seizoenen."
    },
    {
      "nl": "het begin",
      "phonetic": "huht buh-KHIN",
      "en": "the beginning",
      "tip": "Soft 'g'. 'In het begin' = in the beginning."
