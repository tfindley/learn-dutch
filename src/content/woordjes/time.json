      "tip": "'ooi' = 'oy' sound."
    },
    {
      "nl": "soms",
      "phonetic": "soms",
      "en": "sometimes",
      "tip": "Very commonly used."
    },
    {
      "nl": "de minuut",
      "phonetic": "duh mee-NEWT",
      "en": "the minute",
      "tip": "Plural: de minuten. 'Vijf minuten' = five minutes."
    },
    {
      "nl": "het uur",
      "phonetic": "huht uur",
      "en": "the hour",
