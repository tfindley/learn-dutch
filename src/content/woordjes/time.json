      "phonetic": "duh vayk",
      "en": "the week",
      "tip": "Deze week = this week. Plural: de weken."
    },
    {
      "nl": "de maand",
      "phonetic": "duh maant",
      "en": "the month",
      "tip": "Final 'd' → 't'. Plural: de maanden."
    },
    {
      "nl": "het jaar",
      "phonetic": "huht yaar",
      "en": "the year",
      "tip": "Plural: de jaren."
    },
    {
      "nl": "de ochtend",
      "phonetic": "duh OKH-tunt",
      "en": "the morning",
      "tip": "'s Ochtends = in the morning (adverb form)."
    },
    {
      "nl": "de middag",
      "phonetic": "duh MID-dahkh",
      "en": "the afternoon",
      "tip": "'s Middags = in the afternoon. 'Goedemiddag' uses this."
    },
    {
      "nl": "de avond",
      "phonetic": "duh AH-font",
      "en": "the evening",
      "tip": "'s Avonds = in the evening. 'v' → 'f' sound."
    },
    {
      "nl": "de nacht",
      "phonetic": "duh nakht",
      "en": "the night",
      "tip": "Soft 'ch' at end. 's Nachts = at night."
